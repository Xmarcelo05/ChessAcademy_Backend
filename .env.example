# .env.example
# Copiar este archivo a .env y llenar con valores reales

# ===================== CONFIGURACIÓN GENERAL =====================
ENVIRONMENT=development
DEBUG=True
APP_NAME=Chess Academy API
APP_VERSION=1.0.0

# ===================== CORS Y SEGURIDAD =====================
# URL del frontend en Azure (CRÍTICO para CORS)
AZURE_FRONTEND_URL=https://tudominio.azurewebsites.net

# Clave secreta (cambiar en producción)
SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria-cambiar-en-produccion

# ===================== API =====================
API_V1_STR=/api/v1

# ===================== WEBSOCKET =====================
WEBSOCKET_TIMEOUT=30
WEBSOCKET_HEARTBEAT_INTERVAL=30

# ===================== LÍMITES =====================
MAX_INSCRIPCIONES_POR_CORREO=5
TIMEOUT_SOLICITUD=60

# ===================== LOGGING =====================
LOG_LEVEL=INFO

# ===================== TOKENS (OPCIONAL) =====================
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ===================== CONFIGURACIÓN DE BASES DE DATOS (FUTURO) =====================
# DATABASE_URL=postgresql://user:password@localhost/chess_academy_db
# SQLALCHEMY_TRACK_MODIFICATIONS=False

# ===================== CONFIGURACIÓN DE AWS (FUTURO) =====================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ===================== CORREO (FUTURO) =====================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@chessacademy.com

# ===================== PAYPAL/STRIPE (FUTURO) =====================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
